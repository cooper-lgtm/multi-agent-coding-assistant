#!/usr/bin/env node

import fs from 'node:fs';

const statePath = process.env.PLAN_RUNNER_FAKE_STATE;
if (!statePath) {
  process.stderr.write('PLAN_RUNNER_FAKE_STATE is required\n');
  process.exit(1);
}

const argv = process.argv.slice(2);
const state = JSON.parse(fs.readFileSync(statePath, 'utf8'));
state.commands.push({ bin: 'gh', argv });

const [command, rawSubcommand, rawTarget] = argv;
const { subcommand, target, paginate, slurp } = normalizeApiArguments(rawSubcommand, rawTarget, argv);

if (command === 'pr' && subcommand === 'checks') {
  const prNumber = parsePullRequestNumber(target);
  const jsonIndex = argv.indexOf('--json');
  const requestedFields = (jsonIndex >= 0 ? argv[jsonIndex + 1] : 'bucket')
    .split(',')
    .map((field) => field.trim())
    .filter(Boolean);
  const isBucketOnlyRequest = requestedFields.length === 1 && requestedFields[0] === 'bucket';
  state.currentChecksByPr = state.currentChecksByPr ?? {};
  const detailedOverrideQueue = state.checkDetails?.[prNumber];
  const rawDetailedOverrideQueue = state.rawCheckDetails?.[prNumber];
  if (!isBucketOnlyRequest && Array.isArray(rawDetailedOverrideQueue) && rawDetailedOverrideQueue.length > 0) {
    const rawDetailedChecks = shiftQueue(rawDetailedOverrideQueue, {});
    writeState(statePath, state);
    process.stdout.write(JSON.stringify(rawDetailedChecks));
    process.exit(0);
  }
  const nextStatus = !isBucketOnlyRequest && Array.isArray(detailedOverrideQueue) && detailedOverrideQueue.length > 0
    ? shiftQueue(detailedOverrideQueue, state.currentChecksByPr[prNumber] ?? 'pending')
    : (isBucketOnlyRequest || !state.currentChecksByPr[prNumber]
    ? shiftQueue(state.checks[prNumber], 'pending')
    : state.currentChecksByPr[prNumber]);
  state.currentChecksByPr[prNumber] = normalizeCheckEntries(nextStatus);
  writeState(statePath, state);
  process.stdout.write(JSON.stringify(formatCheckBuckets(state.currentChecksByPr[prNumber], requestedFields)));
  process.exit(0);
}

if (command === 'pr' && subcommand === 'view') {
  const prNumber = parsePullRequestNumber(target);
  const jsonIndex = argv.indexOf('--json');
  const jsonField = jsonIndex >= 0 ? argv[jsonIndex + 1] : null;

  if (jsonField === 'mergeable') {
    const nextMergeable = shiftQueue(state.mergeables?.[prNumber], 'UNKNOWN');
    writeState(statePath, state);
    process.stdout.write(nextMergeable);
    process.exit(0);
  }

  if (jsonField === 'mergeStateStatus') {
    const nextMergeStateStatus = shiftQueue(state.mergeStateStatuses?.[prNumber], 'UNKNOWN');
    writeState(statePath, state);
    process.stdout.write(nextMergeStateStatus);
    process.exit(0);
  }

  state.currentHeadShas = state.currentHeadShas ?? {};
  const nextHeadSha = shiftQueue(state.headShas?.[prNumber], state.currentHeadShas[prNumber] ?? '');
  state.currentHeadShas[prNumber] = nextHeadSha;
  writeState(statePath, state);
  process.stdout.write(nextHeadSha);
  process.exit(0);
}

if (command === 'pr' && subcommand === 'merge') {
  const prNumber = parsePullRequestNumber(target);
  state.merged.push(prNumber);
  writeState(statePath, state);
  process.exit(0);
}

if (command === 'api') {
  const apiTarget = subcommand;
  if (typeof apiTarget !== 'string') {
    writeState(statePath, state);
    process.stderr.write('Missing API target\n');
    process.exit(1);
  }

  const reviewMatch = apiTarget.match(/^repos\/([^/]+)\/([^/]+)\/pulls\/(\d+)\/reviews$/);
  if (reviewMatch) {
    const prNumber = reviewMatch[3];
    const headSha = state.currentHeadShas?.[prNumber];
    const nextReview = shiftQueue(state.reviews?.[prNumber]?.[headSha], { status: 'pending' });
    state.currentReviewIds = state.currentReviewIds ?? {};

    if (nextReview.status === 'pending') {
      writeState(statePath, state);
      process.stdout.write(JSON.stringify([]));
      process.exit(0);
    }

    state.currentReviewIds[prNumber] = String(nextReview.review_id);
    writeState(statePath, state);
    process.stdout.write(
      JSON.stringify([
        {
          id: Number(nextReview.review_id),
          commit_id: headSha,
          user: { login: 'chatgpt-codex-connector[bot]' },
        },
      ]),
    );
    process.exit(0);
  }

  const commentMatch = apiTarget.match(/^repos\/([^/]+)\/([^/]+)\/pulls\/(\d+)\/comments$/);
  if (commentMatch) {
    const prNumber = commentMatch[3];
    const reviewId = state.currentReviewIds?.[prNumber];
    const comments = formatCommentPages(state.comments?.[prNumber]?.[reviewId], reviewId, { paginate, slurp });
    writeState(statePath, state);
    process.stdout.write(comments.map((page) => JSON.stringify(page)).join(''));
    process.exit(0);
  }

  const checkRunsMatch = apiTarget.match(/^repos\/([^/]+)\/([^/]+)\/commits\/([^/]+)\/check-runs$/);
  if (checkRunsMatch) {
    const headSha = checkRunsMatch[3];
    const checkRunPages = Array.isArray(state.checkRunPages?.[headSha]) && state.checkRunPages[headSha].length > 0
      ? state.checkRunPages[headSha]
      : [
        {
          total_count: Array.isArray(state.checkRuns?.[headSha]) ? state.checkRuns[headSha].length : 0,
          check_runs: Array.isArray(state.checkRuns?.[headSha]) ? state.checkRuns[headSha] : [],
        },
      ];
    writeState(statePath, state);

    if (slurp) {
      process.stdout.write(JSON.stringify(checkRunPages));
      process.exit(0);
    }

    if (paginate) {
      process.stdout.write(checkRunPages.map((page) => JSON.stringify(page)).join(''));
      process.exit(0);
    }

    process.stdout.write(JSON.stringify(checkRunPages[0] ?? { total_count: 0, check_runs: [] }));
    process.exit(0);
  }
}

writeState(statePath, state);
process.stderr.write(`Unsupported fake gh command: ${argv.join(' ')}\n`);
process.exit(1);

function parsePullRequestNumber(value) {
  const match = String(value).match(/\/pull\/(\d+)$/);
  if (!match) {
    throw new Error(`Could not parse pull request number from ${value}`);
  }

  return match[1];
}

function shiftQueue(queue, fallback) {
  if (!Array.isArray(queue) || queue.length === 0) {
    return fallback;
  }

  return queue.shift();
}

function formatCheckBuckets(entries, requestedFields = ['bucket']) {
  return entries.map((entry) => {
    const projectedEntry = {};
    for (const field of requestedFields) {
      projectedEntry[field] = entry[field] ?? null;
    }
    return projectedEntry;
  });
}

function normalizeCheckEntries(nextStatus) {
  if (Array.isArray(nextStatus)) {
    return nextStatus.map((entry) => normalizeCheckEntry(entry));
  }

  return [normalizeCheckEntry(nextStatus)];
}

function normalizeCheckEntry(entry) {
  if (entry && typeof entry === 'object' && !Array.isArray(entry)) {
    return {
      bucket: entry.bucket ?? 'pending',
      completedAt: entry.completedAt ?? null,
      description: entry.description ?? null,
      event: entry.event ?? null,
      link: entry.link ?? null,
      name: entry.name ?? null,
      startedAt: entry.startedAt ?? null,
      state: entry.state ?? null,
      workflow: entry.workflow ?? null,
    };
  }

  return {
    bucket: entry,
    completedAt: null,
    description: null,
    event: null,
    link: null,
    name: null,
    startedAt: null,
    state: null,
    workflow: null,
  };
}

function normalizeApiArguments(subcommand, target, argv) {
  if (argv[0] !== 'api') {
    return { subcommand, target, paginate: false, slurp: false };
  }

  if (subcommand === '--paginate' && target === '--slurp') {
    return {
      subcommand: argv[3],
      target: argv[4],
      paginate: true,
      slurp: true,
    };
  }

  if (subcommand === '--paginate') {
    return {
      subcommand: target,
      target: argv[3],
      paginate: true,
      slurp: false,
    };
  }

  return {
    subcommand,
    target,
    paginate: false,
    slurp: false,
  };
}

function formatCommentPages(commentState, reviewId, options) {
  if (commentState && typeof commentState === 'object' && !Array.isArray(commentState)) {
    if (Array.isArray(commentState.polls)) {
      const nextPoll = shiftQueue(commentState.polls, []);
      return formatCommentPages(nextPoll, reviewId, options);
    }

    return [[]];
  }

  if (!Array.isArray(commentState)) {
    return [[]];
  }

  if (commentState.length === 0) {
    return [[]];
  }

  if (!Array.isArray(commentState[0])) {
    return [serializeComments(commentState, reviewId)];
  }

  if (options.slurp) {
    return [commentState.map((page) => serializeComments(page, reviewId))];
  }

  if (options.paginate) {
    return commentState.map((page) => serializeComments(page, reviewId));
  }

  return [serializeComments(commentState[0] ?? [], reviewId)];
}

function serializeComments(comments, reviewId) {
  return comments.map((comment) => ({
    user: { login: 'chatgpt-codex-connector[bot]' },
    pull_request_review_id: Number(reviewId),
    path: comment.path ?? null,
    body: comment.body,
  }));
}

function writeState(statePath, state) {
  fs.writeFileSync(statePath, JSON.stringify(state, null, 2));
}
